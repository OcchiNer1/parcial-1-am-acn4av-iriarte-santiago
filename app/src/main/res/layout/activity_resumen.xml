<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.chequeo.FullScreenVideoView
        android:id="@+id/vvBackground"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/bg_overlay_dim"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/cardResumenContenido"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/padding_card_formulario"
        android:background="@drawable/background_card_traslucido"
        android:layout_margin="@dimen/margen_horizontal"
        android:elevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:gravity="center"
            android:text="✓"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:background="@drawable/btn_accent"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:id="@+id/tvResumenMonto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/formato_resumen_monto"
            android:textSize="@dimen/texto_titulo_grande"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvResumenCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/formato_resumen_categoria"
            android:textSize="@dimen/texto_cuerpo"
            android:textColor="@color/texto_muted"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="0dp"
        android:layout_height="@dimen/alto_boton_secundario"
        android:text="@string/btn_volver"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/btn_accent_dark"
        android:elevation="@dimen/elevacion_boton"
        android:layout_margin="@dimen/margen_general"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>